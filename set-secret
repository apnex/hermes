#!/bin/bash
## set-secret — apply hermes-config ConfigMap + hermes-credentials Secret(s) to
##              the cluster from env vars.
##
## Required env: LITELLM_BASE_URL, LITELLM_MODEL, LITELLM_API_KEY, API_SERVER_KEY
## Optional env: DISCORD_BOT_TOKEN, DISCORD_ALLOWED_USERS,
##               GH_TOKEN (GitHub PAT/OAuth token — enables `gh` CLI + git push
##                         from inside the pod; mirrors host's gh auth),
##               HERMES_PEER_NAME (Honcho peer identity; default "default-user"),
##               HERMES_HOST_SSH_KEY (PEM private key, enables `nuc` host shell),
##               NAMESPACE (default: hermes)
##
## What it creates (idempotent — re-runs replace prior values):
##   hermes-config        ConfigMap   non-sensitive (BASE_URL, MODEL, PEER_NAME, DISCORD_ALLOWED_USERS)
##   hermes-credentials   Secret      sensitive    (API_KEY, API_SERVER_KEY, BOT_TOKEN, GH_TOKEN)
##   hermes-host-ssh-key  Secret      separate; only if HERMES_HOST_SSH_KEY is set
set -e

NAMESPACE="${NAMESPACE:-hermes}"

for v in LITELLM_BASE_URL LITELLM_MODEL LITELLM_API_KEY API_SERVER_KEY; do
	if [[ -z "${!v}" ]]; then
		echo "Error: \$${v} is not set" >&2
		exit 1
	fi
done

## namespace (idempotent)
kubectl create namespace "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -

## ── ConfigMap: hermes-config (non-sensitive) ─────────────────────────
CM_ARGS=(
	--from-literal=LITELLM_BASE_URL="${LITELLM_BASE_URL}"
	--from-literal=LITELLM_MODEL="${LITELLM_MODEL}"
)

if [[ -n "${HERMES_PEER_NAME:-}" ]]; then
	CM_ARGS+=( --from-literal=HERMES_PEER_NAME="${HERMES_PEER_NAME}" )
	echo "  + HERMES_PEER_NAME included (honcho peer identity)"
fi

if [[ -n "${DISCORD_ALLOWED_USERS:-}" ]]; then
	CM_ARGS+=( --from-literal=DISCORD_ALLOWED_USERS="${DISCORD_ALLOWED_USERS}" )
	echo "  + DISCORD_ALLOWED_USERS included (DM allowlist)"
fi

kubectl create configmap hermes-config -n "${NAMESPACE}" \
	"${CM_ARGS[@]}" \
	--dry-run=client -o yaml | kubectl apply -f -
echo "hermes-config applied to namespace ${NAMESPACE}"

## ── Secret: hermes-credentials (sensitive) ───────────────────────────
SECRET_ARGS=(
	--from-literal=LITELLM_API_KEY="${LITELLM_API_KEY}"
	--from-literal=API_SERVER_KEY="${API_SERVER_KEY}"
)

if [[ -n "${DISCORD_BOT_TOKEN:-}" ]]; then
	SECRET_ARGS+=( --from-literal=DISCORD_BOT_TOKEN="${DISCORD_BOT_TOKEN}" )
	echo "  + DISCORD_BOT_TOKEN included (Discord gateway will activate)"
fi

if [[ -n "${GH_TOKEN:-}" ]]; then
	SECRET_ARGS+=( --from-literal=GH_TOKEN="${GH_TOKEN}" )
	echo "  + GH_TOKEN included (gh CLI + git push from pod enabled)"
fi

kubectl create secret generic hermes-credentials -n "${NAMESPACE}" \
	"${SECRET_ARGS[@]}" \
	--dry-run=client -o yaml | kubectl apply -f -
echo "hermes-credentials applied to namespace ${NAMESPACE}"

## ── Optional Secret: hermes-host-ssh-key ─────────────────────────────
## Separate from hermes-credentials so the deployment can mount it with
## `optional: true` and start cleanly when host access isn't configured.
if [[ -n "${HERMES_HOST_SSH_KEY:-}" ]]; then
	## Shell `$(cat key)` strips trailing newlines, but PEM keys need a
	## terminating \n or OpenSSL rejects them with "error in libcrypto".
	## Re-add the newline if the env var doesn't already end with one.
	if [[ "${HERMES_HOST_SSH_KEY: -1}" != $'\n' ]]; then
		HERMES_HOST_SSH_KEY="${HERMES_HOST_SSH_KEY}"$'\n'
	fi
	kubectl create secret generic hermes-host-ssh-key -n "${NAMESPACE}" \
		--from-literal=id_ed25519="${HERMES_HOST_SSH_KEY}" \
		--dry-run=client -o yaml | kubectl apply -f -
	echo "  + hermes-host-ssh-key applied (host shell via 'nuc' enabled)"
fi
